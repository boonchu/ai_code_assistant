# =============================================================================
# AI App Proxy - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values
#
# ⚠️ IMPORTANT: Change all secrets in production!
# =============================================================================

# =============================================================================
# SECURITY - REQUIRED
# =============================================================================

# JWT Secret Key for token signing
# Generate a secure random secret (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Key Secret for API key authentication
# Use a different secret from JWT_SECRET
API_KEY_SECRET=your-super-secret-api-key-change-this-in-production

# =============================================================================
# AUTHENTICATION - OPTIONAL
# =============================================================================

# JWT Token expiration time in minutes
# Shorter is more secure, longer is more convenient
ACCESS_TOKEN_EXPIRE_MINUTES=15

# bcrypt password hashing rounds
# Higher = more secure but slower
# Recommended: 12 (balanced), 14 (maximum security)
BCRYPT_ROUNDS=12

# =============================================================================
# BACKEND - OPTIONAL
# =============================================================================

# Backend API URL
BACKEND_URL=http://llama-cpp:8080

# =============================================================================
# RATE LIMITING - OPTIONAL
# =============================================================================

# Maximum requests per window per client IP
RATE_LIMIT_MAX_REQUESTS=100

# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW=60

# =============================================================================
# CORS - OPTIONAL
# =============================================================================

# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourdomain.com
CORS_ALLOW_ORIGINS=http://localhost:3000

# =============================================================================
# NETWORKING - OPTIONAL
# =============================================================================

# Default timeout for backend requests (seconds)
DEFAULT_TIMEOUT=5.0

# =============================================================================
# DATABASE (FUTURE) - OPTIONAL
# =============================================================================

# Database host
# DB_HOST=localhost

# Database port
# DB_PORT=5432

# Database name
# DB_NAME=ai_app

# Database user
# DB_USER=postgres

# Database password
# DB_PASSWORD=

# Enable database migrations
# ENABLE_DB_MIGRATIONS=true

# Database SSL
# DB_SSL=false
