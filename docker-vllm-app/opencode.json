{
  "$schema": "https://opencode.ai/config.json",
  "provider": { "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (local)",
      "models": {
        "Qwen/Qwen3.5-4B": {
          "name": "Qwen/Qwen3.5-4B",
          "options": {
            "system": "You are a Typescript programming expert.",
            "max_tokens": 4096
          }
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "toolParser": [
          {
            "type": "raw-function-call"
          },
          {
            "type": "json"
          }
        ]
      }
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#8ea39819eed74fe2a0338e71789f06b30e953041"
  ],
  "agent": {
    "plan": {
      "options": {
        "system": "You are a Typescript programming expert."
      },
      "permission": {
        "markdown_*": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "build": {
      "options": {
        "system": "You are a Typescript programming expert."
      },
      "permission": {
        "bash": "allow",
        "apply_patch": "allow",
        "edit": "allow",
        "write": "allow"
      }
    },
    "general": {
      "options": {},
      "permission": {
        "bash": "allow"
      }
    }
  }
}
